# =====================================================================
# ForgeOS — environment configuration
# Copy to `.env` and fill in your real keys. Never commit `.env`.
# =====================================================================

# --- LLM providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:latest

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_OWNER=

# --- Railway (backend deploy) ---
RAILWAY_TOKEN=

# --- Vercel (frontend deploy) ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Supabase ---
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# --- Sentry ---
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# --- Uptime Robot ---
UPTIMEROBOT_API_KEY=

# --- Upstash (cache + queue) ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Lemon Squeezy ---
LEMONSQUEEZY_API_KEY=

# --- Runtime ---
FORGEOS_WORKDIR=./.forgeos
OBSIDIAN_VAULT=~/ObsidianVault/ForgeOS
FORGEOS_LOG_LEVEL=INFO
FORGEOS_MAX_AGENT_RETRIES=3
FORGEOS_RETRY_BACKOFF=2.0
FORGEOS_ENABLE_OBSIDIAN=true
FORGEOS_DRY_RUN=false
HEALER_SENTRY_INTERVAL=300
HEALER_UPTIME_INTERVAL=60
