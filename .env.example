# =====================================================================
# ForgeOS — environment configuration
# Copy to .env and fill in your keys. Never commit .env.
#
# ROUTING STRATEGY:
#   Primary  → Ollama (qwen2.5-coder:7b, free, local GPU)
#   Fallback → Claude haiku (cheap, ~$0.01/run)
# =====================================================================

# --- Ollama (primary — free local GPU in WSL2) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Claude (fallback — set key to enable) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- GitHub (required for deploy agent) ---
# Get from: https://github.com/settings/tokens/new
# Scopes: repo, workflow, admin:org (public_repo is enough for public repos)
GITHUB_TOKEN=
GITHUB_OWNER=xenarch   # your GitHub username

# --- Railway (backend deploy) ---
# Get from: https://railway.app/account/tokens
RAILWAY_TOKEN=

# --- Vercel (frontend deploy) ---
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=   # leave blank for personal account

# --- Supabase ---
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# --- Sentry ---
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# --- Uptime Robot ---
# Get from: https://uptimerobot.com/api
UPTIMEROBOT_API_KEY=

# --- Upstash Redis (optional queue/cache) ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- Lemon Squeezy (payments — India compatible) ---
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=

# --- LLM tuning ---
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0

# --- API security ---
# Set a strong random value to require Bearer token auth on all /builds endpoints.
# Leave blank to run without auth (localhost dev only — never expose port 8000
# to the internet without setting this).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FORGEOS_API_KEY=

# --- Runtime ---
FORGEOS_WORKDIR=./.forgeos
OBSIDIAN_VAULT=~/ObsidianVault/ForgeOS
FORGEOS_LOG_LEVEL=INFO
FORGEOS_MAX_AGENT_RETRIES=2
FORGEOS_RETRY_BACKOFF=2.0
FORGEOS_ENABLE_OBSIDIAN=true
FORGEOS_DRY_RUN=false
